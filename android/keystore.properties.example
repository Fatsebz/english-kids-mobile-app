# Modèle pour la signature de release.
# COPIER ce fichier en `keystore.properties` (même dossier) et y mettre TES valeurs.
# `keystore.properties` est gitignoré : il ne doit JAMAIS être commité (mots de passe privés).

# Chemin du keystore, relatif au dossier `android/` (ex. si le .keystore est dans android/).
storeFile=englishkidz-release.keystore
# Mot de passe du keystore.
storePassword=CHANGE_MOI
# Alias de la clé (celui passé à keytool, ex. key0).
keyAlias=key0
# Mot de passe de la clé.
keyPassword=CHANGE_MOI
